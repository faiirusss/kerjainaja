---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-col footer-brand">
      <span class="footer-logo">Kerjain<span class="logo-accent">Aja</span></span>
      <p class="footer-desc">Panduan lengkap cari kerja online di Indonesia. Tips CV, interview, dan rekomendasi platform lowongan terpercaya.</p>
    </div>
    <div class="footer-col">
      <h5>Navigasi</h5>
      <a href="/">Beranda</a>
      <a href="/blog">Blog</a>
      <a href="/tentang">Tentang</a>
      <a href="/kontak">Kontak</a>
    </div>
    <div class="footer-col">
      <h5>Topik</h5>
      <a href="/blog/panduan-membuat-cv-2026">Panduan CV</a>
      <a href="/blog/sukses-interview-kerja-online">Tips Interview</a>
      <a href="/blog/perbandingan-platform-lowongan-kerja">Review Platform</a>
      <a href="/blog/cara-daftar-lowongan-bumn-2026">Lowongan BUMN</a>
    </div>
    <div class="footer-col">
      <h5>Populer</h5>
      <a href="/blog/aplikasi-cari-kerja-gratis-2026">Aplikasi Cari Kerja</a>
      <a href="/blog/kerja-remote-fresh-graduate">Kerja Remote</a>
    </div>
  </div>
  <div class="footer-wordmark" aria-hidden="true">KerjainAja</div>
  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {year} KerjainAja. Semua panduan gratis untuk pencari kerja Indonesia.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    overflow: hidden;
    background: var(--color-ink);
    color: var(--color-canvas-soft);
    padding: var(--space-3xl) 0 0;
    margin-top: var(--space-4xl);
  }
  .footer::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(255, 254, 251, 0.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 254, 251, 0.04) 1px, transparent 1px);
    background-size: 56px 56px;
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 0%, #000, transparent 75%);
    mask-image: radial-gradient(ellipse 80% 70% at 50% 0%, #000, transparent 75%);
    pointer-events: none;
  }
  .footer-inner {
    position: relative;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-3xl);
    padding-bottom: var(--space-3xl);
  }
  .footer-wordmark {
    position: relative;
    text-align: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(48px, 14vw, 180px);
    line-height: 0.9;
    letter-spacing: -4px;
    color: rgba(255, 254, 251, 0.04);
    user-select: none;
    margin: var(--space-2xl) 0 calc(var(--space-2xl) * -0.4);
  }
  .footer-logo {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 600;
    color: var(--color-on-primary);
    letter-spacing: -0.3px;
  }
  .logo-accent { color: var(--color-primary); }
  .footer-desc {
    font-size: 14px;
    line-height: 21px;
    color: var(--color-body-mid);
    margin-top: var(--space-md);
    max-width: 280px;
  }
  .footer-col h5 {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 14px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-on-primary);
    margin-bottom: var(--space-lg);
  }
  .footer-col a {
    display: block;
    color: var(--color-body-mid);
    font-size: 16px;
    line-height: 24px;
    text-decoration: none;
    margin-bottom: var(--space-sm);
    transition: color 0.2s;
  }
  .footer-col a:hover {
    color: var(--color-primary);
    text-decoration: none;
  }
  .footer-bottom {
    position: relative;
    border-top: 1px solid rgba(255, 254, 251, 0.08);
    padding: var(--space-xl) 0;
    font-size: 14px;
    line-height: 21px;
    color: var(--color-body-mid);
  }
  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-xl);
    }
    .footer-brand { grid-column: 1 / -1; }
  }
</style>
