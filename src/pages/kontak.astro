---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Kontak"
  description="Hubungi tim KerjainAja untuk pertanyaan, saran, atau kerjasama. Kami senang mendengar dari Anda."
>
  <section class="band-light">
    <div class="container contact-container">
      <span class="eyebrow">Kontak</span>
      <h1>Hubungi Kami</h1>
      <p class="contact-sub">Punya pertanyaan, saran, atau mau kerjasama? Kami senang mendengar dari Anda.</p>
    </div>
  </section>

  <section class="band-cream">
    <div class="container contact-grid">
      <div class="contact-info">
        <div class="card info-card">
          <strong>✉️ Email</strong>
          <p>hello@kerjainaja.vercel.app</p>
        </div>
        <div class="card info-card">
          <strong>💬 Respons</strong>
          <p>Kami biasanya membalas dalam 1-2 hari kerja.</p>
        </div>
        <div class="card info-card">
          <strong>📍 Lokasi</strong>
          <p>Indonesia</p>
        </div>
      </div>

      <form class="contact-form card" method="POST" action="/kontak" netlify>
        <label>
          Nama
          <input type="text" name="name" required placeholder="Nama lengkap" class="text-input" />
        </label>
        <label>
          Email
          <input type="email" name="email" required placeholder="email@example.com" class="text-input" />
        </label>
        <label>
          Pesan
          <textarea name="message" rows="5" required placeholder="Tulis pesan Anda di sini..." class="text-input"></textarea>
        </label>
        <button type="submit" class="btn btn-primary">Kirim Pesan</button>
      </form>
    </div>
  </section>
</Layout>

<style>
  .contact-container { max-width: 780px; margin: 0 auto; }
  .contact-container h1 { margin-bottom: var(--space-lg); }
  .contact-sub {
    font-size: 20px;
    line-height: 30px;
    color: var(--color-body);
    max-width: 500px;
  }
  .contact-grid {
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: var(--space-3xl);
    align-items: start;
  }
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .info-card strong {
    display: block;
    margin-bottom: var(--space-xs);
    font-size: 18px;
    font-weight: 600;
    color: var(--color-ink);
  }
  .info-card p {
    font-size: 16px;
    line-height: 24px;
    color: var(--color-body);
    margin: 0;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .contact-form label {
    display: flex;
    flex-direction: column;
    font-size: 16px;
    font-weight: 600;
    color: var(--color-ink);
    gap: var(--space-xs);
  }
  .contact-form textarea { resize: vertical; }
  .contact-form button { align-self: flex-start; }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; }
  }
</style>
