---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Kontak"
  description="Hubungi tim KerjainAja untuk pertanyaan, saran, atau kerjasama. Kami senang mendengar dari Anda."
>
  <section class="contact">
    <h1>Hubungi Kami</h1>
    <p class="contact-sub">Punya pertanyaan, saran, atau mau kerjasama? Silakan isi form di bawah atau kirim email langsung.</p>

    <div class="contact-grid">
      <div class="contact-info">
        <div class="info-item">
          <strong>✉️ Email</strong>
          <p>hello@kerjainaja.vercel.app</p>
        </div>
        <div class="info-item">
          <strong>💬 Respons</strong>
          <p>Kami biasany membalas dalam 1-2 hari kerja.</p>
        </div>
        <div class="info-item">
          <strong>📍 Lokasi</strong>
          <p>Indonesia</p>
        </div>
      </div>

      <form class="contact-form" method="POST" action="/kontak" netlify>
        <label>
          Nama
          <input type="text" name="name" required placeholder="Nama lengkap" />
        </label>
        <label>
          Email
          <input type="email" name="email" required placeholder="email@example.com" />
        </label>
        <label>
          Pesan
          <textarea name="message" rows="5" required placeholder="Tulis pesan Anda di sini..."></textarea>
        </label>
        <button type="submit" class="btn btn-primary">Kirim Pesan</button>
      </form>
    </div>
  </section>
</Layout>

<style>
  .contact h1 {
    margin-bottom: 0.75rem;
  }
  .contact-sub {
    color: #6b7280;
    margin-bottom: 2rem;
    max-width: 500px;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
  }
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .info-item strong {
    display: block;
    margin-bottom: 0.25rem;
    font-size: 1rem;
    color: #111827;
  }
  .info-item p {
    color: #6b7280;
    font-size: 0.9rem;
    margin: 0;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .contact-form label {
    display: flex;
    flex-direction: column;
    font-size: 0.9rem;
    font-weight: 600;
    color: #374151;
    gap: 0.35rem;
  }
  .contact-form input,
  .contact-form textarea {
    padding: 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    font-size: 1rem;
    font-family: inherit;
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }
  .contact-form button {
    align-self: flex-start;
  }
  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; }
  }
</style>
