---
import Layout from '../layouts/Layout.astro';

const site = 'https://kerjainaja.vercel.app';

const landingSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${site}/#webpage`,
      "url": site,
      "name": "KerjainAja — Panduan Lengkap Cari Kerja Online di Indonesia",
      "description": "Panduan lengkap cari kerja online di Indonesia. Tips CV ATS-friendly, trik interview, dan rekomendasi platform lowongan kerja terpercaya.",
    },
    {
      "@type": "Organization",
      "@id": `${site}/#organization`,
      "name": "KerjainAja",
      "url": site,
      "areaServed": "Indonesia"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Platform lowongan kerja apa yang terpercaya di Indonesia?",
          "acceptedAnswer": { "@type": "Answer", "text": "JobStreet, LinkedIn, Glints, dan Indeed adalah platform yang sudah terbukti terpercaya. Untuk lowongan pemerintah/BUMN, cek Karirhub Kemnaker." }
        },
        {
          "@type": "Question",
          "name": "Bagaimana cara membuat CV yang menarik?",
          "acceptedAnswer": { "@type": "Answer", "text": "Gunakan format ATS-friendly, fokus ke pencapaian bukan hanya tugas, sesuaikan keyword dengan posisi, dan simpan dalam format PDF." }
        },
        {
          "@type": "Question",
          "name": "Apakah melamar kerja online aman?",
          "acceptedAnswer": { "@type": "Answer", "text": "Aman selama pakai platform resmi. Waspada jika diminta bayar atau data rekening." }
        }
      ]
    }
  ]
};
---

<Layout
  title="Panduan Lengkap Cari Kerja Online di Indonesia"
  description="Panduan lengkap cari kerja online di Indonesia. Dapatkan tips CV ATS-friendly, trik lolos interview, dan rekomendasi platform lowongan kerja terpercaya 2026."
  ogType="website"
  canonical={site}
  schema={landingSchema}
>
  <!-- ── Hero ── -->
  <section class="hero-section">
    <div class="container hero-layout">
      <div class="hero-text fade-in-up">
        <span class="eyebrow">Panduan Karir Terlengkap</span>
        <h1>Panduan Lengkap <span class="text-primary">Cari Kerja Online</span> di Indonesia</h1>
        <p class="hero-lead">Tips CV ATS-friendly, trik lolos interview, review platform lowongan terpercaya — semuanya gratis, dari fresh graduate sampai profesional.</p>
        <div class="hero-actions">
          <a href="/blog" class="btn btn-primary btn-lg">Jelajahi Semua Panduan →</a>
          <a href="/tentang" class="btn btn-tertiary">Tentang Kami</a>
        </div>
        <div class="hero-metrics">
          <div class="metric"><span class="metric-num">6</span> Artikel</div>
          <div class="metric"><span class="metric-num">10+</span> Platform</div>
          <div class="metric"><span class="metric-num">100%</span> Gratis</div>
        </div>
      </div>
      <div class="hero-visual fade-in-up delay-200">
        <div class="hero-card-stack">
          <div class="hc hc-1">
            <div class="hc-icon">📝</div>
            <div class="hc-text">
              <strong>Panduan CV 2026</strong>
              <span>Bikin CV ATS-friendly</span>
            </div>
            <a href="/blog/panduan-membuat-cv-2026" class="hc-arrow">→</a>
          </div>
          <div class="hc hc-2">
            <div class="hc-icon">🎯</div>
            <div class="hc-text">
              <strong>Tips Interview</strong>
              <span>Lolos wawancara online</span>
            </div>
            <a href="/blog/sukses-interview-kerja-online" class="hc-arrow">→</a>
          </div>
          <div class="hc hc-3">
            <div class="hc-icon">🔍</div>
            <div class="hc-text">
              <strong>Review Platform</strong>
              <span>JobStreet vs LinkedIn</span>
            </div>
            <a href="/blog/perbandingan-platform-lowongan-kerja" class="hc-arrow">→</a>
          </div>
          <div class="hc hc-4">
            <div class="hc-icon">🏛️</div>
            <div class="hc-text">
              <strong>Lowongan BUMN</strong>
              <span>Cara daftar 2026</span>
            </div>
            <a href="/blog/cara-daftar-lowongan-bumn-2026" class="hc-arrow">→</a>
          </div>
          <div class="hc hc-5">
            <div class="hc-icon">💼</div>
            <div class="hc-text">
              <strong>Kerja Remote</strong>
              <span>Panduan fresh graduate</span>
            </div>
            <a href="/blog/kerja-remote-fresh-graduate" class="hc-arrow">→</a>
          </div>
          <div class="hc hc-6">
            <div class="hc-icon">📱</div>
            <div class="hc-text">
              <strong>Aplikasi Cari Kerja</strong>
              <span>10 platform gratis 2026</span>
            </div>
            <a href="/blog/aplikasi-cari-kerja-gratis-2026" class="hc-arrow">→</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Trust Bar ── -->
  <section class="trust-bar">
    <div class="container">
      <p class="trust-label">Panduan untuk pencari kerja dari berbagai platform</p>
      <div class="trust-logos">
        <span class="trust-logo">JobStreet</span>
        <span class="trust-logo">LinkedIn</span>
        <span class="trust-logo">Glints</span>
        <span class="trust-logo">Indeed</span>
        <span class="trust-logo">Karirhub</span>
      </div>
    </div>
  </section>

  <!-- ── Features ── -->
  <section class="section section-cream">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Layanan</span>
        <h2>Semua yang kamu butuhkan untuk <span class="text-primary">cari kerja</span></h2>
        <p class="section-sub">Dari langkah pertama sampai tanda tangan kontrak — panduan lengkap di satu tempat.</p>
      </div>
      <div class="feature-grid fade-in-up">
        <a href="/blog/panduan-membuat-cv-2026" class="feature-card">
          <span class="feature-icon">📝</span>
          <h3>Panduan CV & Lamaran</h3>
          <p>Bikin CV ATS-friendly yang dilirik HRD, lengkap dengan template dan contoh surat lamaran.</p>
          <span class="feature-cta">Baca Panduan →</span>
        </a>
        <a href="/blog/sukses-interview-kerja-online" class="feature-card">
          <span class="feature-icon">🎯</span>
          <h3>Persiapan Interview</h3>
          <p>Pertanyaan yang sering muncul, teknik STAR, dan simulasi interview online dari rumah.</p>
          <span class="feature-cta">Baca Panduan →</span>
        </a>
        <a href="/blog/perbandingan-platform-lowongan-kerja" class="feature-card">
          <span class="feature-icon">🔍</span>
          <h3>Review Platform</h3>
          <p>Bandingkan JobStreet, LinkedIn, Glints, Indeed, Karirhub — plus kelebihan & kekurangannya.</p>
          <span class="feature-cta">Bandingkan →</span>
        </a>
        <a href="/blog/kerja-remote-fresh-graduate" class="feature-card">
          <span class="feature-icon">💼</span>
          <h3>Tips Karir Remote</h3>
          <p>Panduan kerja WFH untuk fresh graduate — platform, skill, dan cara mulai dari nol.</p>
          <span class="feature-cta">Cari Tahu →</span>
        </a>
        <a href="/blog/aplikasi-cari-kerja-gratis-2026" class="feature-card">
          <span class="feature-icon">📱</span>
          <h3>Aplikasi Cari Kerja</h3>
          <p>10 aplikasi cari kerja gratis terbaik 2026 — fitur, kelebihan, dan cara optimasi profil.</p>
          <span class="feature-cta">Lihat Aplikasi →</span>
        </a>
        <a href="/blog/cara-daftar-lowongan-bumn-2026" class="feature-card">
          <span class="feature-icon">🏛️</span>
          <h3>Lowongan BUMN 2026</h3>
          <p>Panduan lengkap dari pendaftaran FHCI, tes TKD & Akhlak, sampai tips lolos wawancara.</p>
          <span class="feature-cta">Pelajari →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Stats / Numbers ── -->
  <section class="section section-stats">
    <div class="container">
      <div class="stats-grid fade-in-up">
        <div class="stat-card">
          <span class="stat-num">6</span>
          <span class="stat-label">Artikel Panduan</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">10+</span>
          <span class="stat-label">Platform di-review</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">5</span>
          <span class="stat-label">Topik Karir</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">100%</span>
          <span class="stat-label">Gratis Selamanya</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Dark CTA ── -->
  <section class="section section-dark">
    <div class="container cta-block fade-in-up">
      <span class="eyebrow" style="color: var(--color-body-mid);">Mulai Sekarang</span>
      <h2 style="color: var(--color-on-primary);">Siap mulai karir impian?</h2>
      <p class="cta-text">Jangan biarkan kebingungan menghambat langkahmu. Dapatkan panduan lengkap, tips terbaru, dan rekomendasi platform lowongan kerja — semua gratis.</p>
      <a href="/blog" class="btn btn-primary btn-lg">Jelajahi Semua Panduan →</a>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="section section-light">
    <div class="container faq-block">
      <div class="section-head">
        <span class="eyebrow">FAQ</span>
        <h2>Pertanyaan yang Sering Diajukan</h2>
      </div>
      <div class="faq-list fade-in-up">
        <details class="faq-item">
          <summary>Platform lowongan kerja apa yang paling terpercaya?</summary>
          <p>JobStreet, LinkedIn, Glints, dan Indeed adalah platform yang sudah terbukti terpercaya. Untuk lowongan pemerintah/BUMN, cek Karirhub Kemnaker dan portal SSCASN.</p>
        </details>
        <details class="faq-item">
          <summary>Bagaimana cara bikin CV yang dilirik HRD?</summary>
          <p>Gunakan format ATS-friendly, fokus ke pencapaian (bukan tugas), sesuaikan keyword dengan posisi, dan pastikan kontak jelas. Simpan dalam format PDF.</p>
        </details>
        <details class="faq-item">
          <summary>Apakah melamar kerja online aman?</summary>
          <p>Aman selama pakai platform resmi. Waspada jika diminta bayar, transfer, atau data rekening. Jangan pernah kirim uang untuk biaya administrasi lowongan.</p>
        </details>
        <details class="faq-item">
          <summary>Fresh graduate, mulai dari mana?</summary>
          <p>Mulai dengan riset industri yang cocok, perbarui LinkedIn, bikin CV yang menonjolkan magang/organisasi, dan apply minimal 5-10 lamaran per minggu secara konsisten.</p>
        </details>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Animations ── */
  .fade-in-up {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.6s ease-out forwards;
  }
  .delay-200 { animation-delay: 0.2s; }
  .delay-400 { animation-delay: 0.4s; }

  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Hero ── */
  .hero-section {
    padding: var(--space-4xl) 0 var(--space-3xl);
    background: var(--color-canvas);
  }
  .hero-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }
  .text-primary { color: var(--color-primary); }
  .hero-lead {
    font-size: 18px;
    line-height: 28px;
    color: var(--color-body);
    margin: var(--space-xl) 0 var(--space-2xl);
    max-width: 500px;
  }
  .hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-3xl);
  }
  .btn-lg {
    font-size: 18px;
    padding: var(--space-md) var(--space-2xl);
    line-height: 27px;
  }
  .hero-metrics {
    display: flex;
    gap: var(--space-2xl);
  }
  .metric {
    font-size: 15px;
    line-height: 22px;
    color: var(--color-body-mid);
  }
  .metric-num {
    display: block;
    font-size: 24px;
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: -0.5px;
  }

  /* ── Hero Card Stack ── */
  .hero-card-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    position: relative;
  }
  .hc {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    background: var(--color-canvas-soft);
    padding: var(--space-lg) var(--space-xl);
    border-radius: var(--radius-md);
    border: 1px solid rgba(32, 21, 21, 0.06);
    transition: all 0.2s;
    text-decoration: none;
    color: inherit;
  }
  .hc:hover {
    border-color: var(--color-primary);
    transform: translateX(6px);
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(255, 79, 0, 0.1);
  }
  .hc-icon { font-size: 24px; flex-shrink: 0; }
  .hc-text { flex: 1; }
  .hc-text strong {
    display: block;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-ink);
  }
  .hc-text span {
    font-size: 13px;
    color: var(--color-body-mid);
  }
  .hc-arrow {
    font-size: 18px;
    color: var(--color-primary);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .hc:hover .hc-arrow { opacity: 1; }

  /* ── Trust Bar ── */
  .trust-bar {
    padding: var(--space-2xl) 0;
    background: var(--color-canvas);
    border-top: 1px solid rgba(32, 21, 21, 0.04);
    border-bottom: 1px solid rgba(32, 21, 21, 0.04);
  }
  .trust-label {
    text-align: center;
    font-size: 13px;
    color: var(--color-body-mid);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
  }
  .trust-logos {
    display: flex;
    justify-content: center;
    gap: var(--space-3xl);
    flex-wrap: wrap;
  }
  .trust-logo {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-body-mid);
    opacity: 0.6;
    letter-spacing: -0.3px;
  }

  /* ── Sections ── */
  .section {
    padding: var(--space-4xl) 0;
  }
  .section-cream { background: var(--color-canvas-soft); }
  .section-light { background: var(--color-canvas); }
  .section-dark {
    background: var(--color-ink);
    color: var(--color-on-primary);
  }
  .section-head {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--space-3xl);
  }
  .section-head h2 { margin-bottom: var(--space-md); }
  .section-sub {
    font-size: 18px;
    line-height: 27px;
    color: var(--color-body);
  }

  /* ── Feature Grid ── */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }
  .feature-card {
    background: var(--color-canvas);
    padding: var(--space-2xl);
    border-radius: var(--radius-md);
    border: 1px solid rgba(32, 21, 21, 0.06);
    text-decoration: none;
    color: inherit;
    transition: all 0.25s;
  }
  .feature-card:hover {
    border-color: rgba(255, 79, 0, 0.3);
    box-shadow: 0 8px 24px rgba(255, 79, 0, 0.08);
    transform: translateY(-3px);
    text-decoration: none;
  }
  .feature-icon { font-size: 32px; display: block; margin-bottom: var(--space-lg); }
  .feature-card h3 {
    font-size: 18px;
    font-weight: 600;
    line-height: 24px;
    margin-bottom: var(--space-sm);
    color: var(--color-ink);
  }
  .feature-card p {
    font-size: 15px;
    line-height: 22px;
    color: var(--color-body);
    margin-bottom: var(--space-lg);
  }
  .feature-cta {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary);
  }

  /* ── Stats ── */
  .section-stats { background: var(--color-canvas); padding: var(--space-3xl) 0; }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-xl);
  }
  .stat-card {
    text-align: center;
    padding: var(--space-xl);
  }
  .stat-num {
    display: block;
    font-size: 40px;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
    margin-bottom: var(--space-sm);
    letter-spacing: -1px;
  }
  .stat-label {
    font-size: 15px;
    color: var(--color-body-mid);
  }

  /* ── CTA ── */
  .cta-block {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }
  .cta-block h2 { margin-bottom: var(--space-md); }
  .cta-text {
    font-size: 18px;
    line-height: 27px;
    color: var(--color-body-mid);
    margin-bottom: var(--space-2xl);
  }

  /* ── FAQ ── */
  .faq-block { max-width: 720px; margin: 0 auto; }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .faq-item {
    background: var(--color-canvas-soft);
    padding: var(--space-lg) var(--space-xl);
    border-radius: var(--radius-md);
    border: 1px solid rgba(32, 21, 21, 0.06);
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .faq-item:hover { border-color: rgba(255, 79, 0, 0.2); }
  .faq-item summary {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-ink);
    cursor: pointer;
    outline: none;
  }
  .faq-item p {
    margin-top: var(--space-md);
    color: var(--color-body);
    font-size: 15px;
    line-height: 22px;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .feature-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .hero-layout { grid-template-columns: 1fr; }
    .hero-visual { display: none; }
    .feature-grid { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: var(--space-lg); }
    .stat-num { font-size: 32px; }
    .hero-metrics { gap: var(--space-xl); }
    .trust-logos { gap: var(--space-xl); }
  }
</style>
