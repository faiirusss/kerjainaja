---
import Layout from '../layouts/Layout.astro';

const site = 'https://kerjainaja.vercel.app';

const landingSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${site}/#webpage`,
      "url": site,
      "name": "KerjainAja — Panduan Lengkap Cari Kerja Online di Indonesia",
      "description": "Panduan lengkap cari kerja online di Indonesia. Tips CV ATS-friendly, trik interview, dan rekomendasi platform lowongan kerja terpercaya.",
    },
    {
      "@type": "Organization",
      "@id": `${site}/#organization`,
      "name": "KerjainAja",
      "url": site,
      "description": "Panduan lengkap cari kerja online di Indonesia.",
      "areaServed": "Indonesia"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Apa itu KerjainAja?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "KerjainAja adalah platform panduan lengkap cari kerja online di Indonesia. Kami menyediakan tips CV, persiapan interview, review platform lowongan kerja, dan informasi karir terkini."
          }
        },
        {
          "@type": "Question",
          "name": "Platform lowongan kerja apa yang terpercaya di Indonesia?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "JobStreet, LinkedIn, Glints, dan Indeed adalah platform yang sudah terbukti terpercaya. Untuk lowongan pemerintah/BUMN, cek Karirhub Kemnaker."
          }
        },
        {
          "@type": "Question",
          "name": "Bagaimana cara membuat CV yang menarik?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gunakan format ATS-friendly, fokus ke pencapaian bukan hanya tugas, sesuaikan keyword dengan posisi, dan simpan dalam format PDF."
          }
        },
        {
          "@type": "Question",
          "name": "Apakah melamar kerja online aman?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Aman selama pakai platform resmi. Waspada jika diminta bayar, transfer, atau data rekening. Jangan pernah kirim uang untuk biaya administrasi lowongan."
          }
        }
      ]
    }
  ]
};
---

<Layout
  title="Panduan Lengkap Cari Kerja Online di Indonesia"
  description="Panduan lengkap cari kerja online di Indonesia. Dapatkan tips CV ATS-friendly, trik lolos interview, dan rekomendasi platform lowongan kerja terpercaya 2026."
  ogType="website"
  canonical={site}
  schema={landingSchema}
>
  <!-- Hero Band -->
  <section class="band-hero">
    <div class="container hero-split">
      <div class="hero-text">
        <span class="eyebrow">Panduan Karir</span>
        <h1>Panduan Lengkap<br /><span class="highlight">Cari Kerja Online</span><br />di Indonesia</h1>
        <p class="hero-lead">Dari bikin CV ATS-friendly, persiapan interview, sampai daftar platform lowongan kerja terpercaya — semua gratis.</p>
        <div class="hero-actions">
          <a href="/blog" class="btn btn-primary">Jelajahi Panduan →</a>
          <a href="/tentang" class="btn btn-tertiary">Tentang Kami</a>
        </div>
        <div class="hero-stats">
          <div class="stat"><strong>6</strong> Artikel Panduan</div>
          <div class="stat"><strong>10+</strong> Platform Review</div>
          <div class="stat"><strong>100%</strong> Gratis</div>
        </div>
      </div>
      <div class="hero-visual">
        <svg width="480" height="480" viewBox="0 0 480 480" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="80" y="120" width="320" height="240" rx="12" fill="#f8f4f0" stroke="#201515" stroke-width="1.5"/>
          <rect x="140" y="150" width="200" height="12" rx="6" fill="#201515" opacity="0.3"/>
          <rect x="140" y="175" width="160" height="8" rx="4" fill="#939084"/>
          <rect x="140" y="195" width="180" height="8" rx="4" fill="#939084"/>
          <rect x="140" y="215" width="140" height="8" rx="4" fill="#939084"/>
          <circle cx="120" cy="156" r="8" fill="#ff4f00"/>
          <rect x="140" y="255" width="100" height="36" rx="12" fill="#ff4f00"/>
          <text x="190" y="279" font-family="Inter, sans-serif" font-size="12" fill="#fffefb" text-anchor="middle" font-weight="600">Lihat Panduan</text>
          <path d="M200 330 L240 360 L280 330" stroke="#201515" stroke-width="2" fill="none" opacity="0.4"/>
          <rect x="100" y="380" width="80" height="80" rx="12" fill="#201515"/>
          <text x="140" y="428" font-family="Inter, sans-serif" font-size="28" fill="#fffefb" text-anchor="middle" font-weight="600">CV</text>
          <rect x="200" y="380" width="80" height="80" rx="12" fill="#f8f4f0" stroke="#201515" stroke-width="1"/>
          <text x="240" y="428" font-family="Inter, sans-serif" font-size="28" fill="#201515" text-anchor="middle" font-weight="600">🎯</text>
          <rect x="300" y="380" width="80" height="80" rx="12" fill="#f8f4f0" stroke="#201515" stroke-width="1"/>
          <text x="340" y="428" font-family="Inter, sans-serif" font-size="28" fill="#201515" text-anchor="middle" font-weight="600">💼</text>
        </svg>
      </div>
    </div>
  </section>

  <!-- Features Band (Cream) -->
  <section class="band-cream">
    <div class="container">
      <span class="eyebrow">Layanan</span>
      <h2>Apa yang Kami Sediakan</h2>
      <div class="features-grid">
        <article class="card feature-card">
          <a href="/blog/panduan-membuat-cv-2026" class="feature-link">
            <span class="feature-icon">📝</span>
            <h4>Panduan CV & Lamaran</h4>
            <p>Tips bikin CV ATS-friendly yang dilirik HRD, contoh surat lamaran, dan strategi personal branding.</p>
            <span class="btn btn-text">Baca Panduan</span>
          </a>
        </article>
        <article class="card feature-card">
          <a href="/blog/sukses-interview-kerja-online" class="feature-link">
            <span class="feature-icon">🎯</span>
            <h4>Persiapan Interview</h4>
            <p>Pertanyaan yang sering muncul, cara menjawab dengan teknik STAR, dan simulasi interview online.</p>
            <span class="btn btn-text">Baca Panduan</span>
          </a>
        </article>
        <article class="card feature-card">
          <a href="/blog/perbandingan-platform-lowongan-kerja" class="feature-link">
            <span class="feature-icon">🔍</span>
            <h4>Review Platform</h4>
            <p>Perbandingan JobStreet, LinkedIn, Glints, Indeed, Karirhub — lengkap dengan kelebihan dan kekurangan.</p>
            <span class="btn btn-text">Bandingkan</span>
          </a>
        </article>
        <article class="card feature-card">
          <a href="/blog/kerja-remote-fresh-graduate" class="feature-link">
            <span class="feature-icon">💼</span>
            <h4>Tips Karir Remote</h4>
            <p>Panduan kerja remote untuk fresh graduate — platform, skill yang dibutuhkan, dan cara memulai dari nol.</p>
            <span class="btn btn-text">Cari Tahu</span>
          </a>
        </article>
        <article class="card feature-card">
          <a href="/blog/aplikasi-cari-kerja-gratis-2026" class="feature-link">
            <span class="feature-icon">📱</span>
            <h4>Aplikasi Cari Kerja</h4>
            <p>10 aplikasi cari kerja gratis terbaik 2026 — lengkap dengan fitur, kelebihan, dan tips optimalisasi profil.</p>
            <span class="btn btn-text">Lihat Aplikasi</span>
          </a>
        </article>
        <article class="card feature-card">
          <a href="/blog/cara-daftar-lowongan-bumn-2026" class="feature-link">
            <span class="feature-icon">🏛️</span>
            <h4>Lowongan BUMN 2026</h4>
            <p>Panduan daftar BUMN lengkap dari pendaftaran, tes TKD, tes Akhlak, sampai tips lolos wawancara.</p>
            <span class="btn btn-text">Pelajari</span>
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- CTA Dark Band -->
  <section class="band-hero-dark">
    <div class="container cta-content">
      <span class="eyebrow" style="color: var(--color-body-mid);">Mulai Sekarang</span>
      <h2 style="color: var(--color-on-primary);">Siap Mulai Karir Impian?</h2>
      <p class="cta-lead">Jangan biarkan kebingungan menghambat langkahmu. Dapatkan panduan lengkap, tips terbaru, dan rekomendasi platform lowongan kerja — semuanya gratis.</p>
      <a href="/blog" class="btn btn-primary">Jelajahi Semua Panduan →</a>
    </div>
  </section>

  <!-- FAQ Band -->
  <section class="band-light">
    <div class="container faq-section">
      <span class="eyebrow">FAQ</span>
      <h2>Pertanyaan yang Sering Diajukan</h2>
      <div class="faq-list">
        <details class="faq-item card" open>
          <summary>Platform lowongan kerja apa yang paling terpercaya?</summary>
          <p>JobStreet, LinkedIn, Glints, dan Indeed adalah platform yang sudah terbukti terpercaya. Untuk lowongan pemerintah/BUMN, cek Karirhub Kemnaker dan portal SSCASN.</p>
        </details>
        <details class="faq-item card">
          <summary>Bagaimana cara bikin CV yang dilirik HRD?</summary>
          <p>Gunakan format ATS-friendly, fokus ke pencapaian (bukan tugas), sesuaikan keyword dengan posisi, dan pastikan kontak jelas. Simpan dalam format PDF.</p>
        </details>
        <details class="faq-item card">
          <summary>Apakah melamar kerja online aman?</summary>
          <p>Aman selama pakai platform resmi. Waspada jika diminta bayar, transfer, atau data rekening. Jangan pernah kirim uang untuk biaya administrasi lowongan.</p>
        </details>
        <details class="faq-item card">
          <summary>Fresh graduate, mulai dari mana?</summary>
          <p>Mulai dengan riset industri yang cocok, perbarui LinkedIn, bikin CV yang menonjolkan magang/organisasi, dan apply minimal 5-10 lamaran per minggu secara konsisten.</p>
        </details>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero Split ── */
  .hero-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }
  .highlight { color: var(--color-primary); }
  .hero-lead {
    font-size: 20px;
    line-height: 30px;
    letter-spacing: -0.2px;
    color: var(--color-body);
    margin: var(--space-xl) 0 var(--space-2xl);
    max-width: 520px;
  }
  .hero-actions {
    display: flex;
    gap: var(--space-md);
    margin-bottom: var(--space-3xl);
    flex-wrap: wrap;
  }
  .hero-stats {
    display: flex;
    gap: var(--space-2xl);
  }
  .stat {
    font-size: 16px;
    line-height: 24px;
    color: var(--color-body);
  }
  .stat strong {
    display: block;
    font-size: 20px;
    font-weight: 600;
    color: var(--color-ink);
  }
  .hero-visual svg {
    width: 100%;
    height: auto;
    max-width: 480px;
  }

  /* ── Features Grid ── */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    margin-top: var(--space-3xl);
  }
  .feature-card {
    transition: box-shadow 0.2s;
  }
  .feature-card:hover {
    box-shadow: var(--shadow-soft);
  }
  .feature-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .feature-link:hover { text-decoration: none; }
  .feature-icon {
    font-size: 32px;
    display: block;
    margin-bottom: var(--space-lg);
  }
  .feature-card h4 {
    margin-bottom: var(--space-sm);
  }
  .feature-card p {
    font-size: 16px;
    line-height: 24px;
    color: var(--color-body);
    margin-bottom: var(--space-lg);
  }

  /* ── CTA ── */
  .cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }
  .cta-lead {
    font-size: 20px;
    line-height: 30px;
    color: var(--color-body-mid);
    margin: var(--space-lg) 0 var(--space-2xl);
  }
  .cta-content .btn-primary {
    font-size: 18px;
    padding: var(--space-md) var(--space-2xl);
  }

  /* ── FAQ ── */
  .faq-section {
    max-width: 720px;
    margin: 0 auto;
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-top: var(--space-2xl);
  }
  .faq-item {
    cursor: pointer;
    padding: var(--space-lg) var(--space-xl);
  }
  .faq-item summary {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 27px;
    color: var(--color-ink);
    cursor: pointer;
    outline: none;
  }
  .faq-item p {
    margin-top: var(--space-md);
    color: var(--color-body);
    font-size: 16px;
    line-height: 24px;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .hero-split { grid-template-columns: 1fr; }
    .hero-visual { display: none; }
    .features-grid { grid-template-columns: 1fr; }
    .hero-stats { gap: var(--space-xl); }
  }
</style>
