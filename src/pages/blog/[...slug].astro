---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const postSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": post.data.title,
      "description": post.data.description,
      "author": { "@type": "Person", "name": post.data.author },
      "datePublished": post.data.pubDate.toISOString(),
      "dateModified": (post.data.updatedDate || post.data.pubDate).toISOString(),
      "publisher": { "@type": "Organization", "name": "KerjainAja" },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": `https://kerjainaja.vercel.app/blog/${post.id}`
      },
      "image": post.data.image || "https://kerjainaja.vercel.app/og-image.svg"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Beranda", "item": "https://kerjainaja.vercel.app/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://kerjainaja.vercel.app/blog" },
        { "@type": "ListItem", "position": 3, "name": post.data.title, "item": `https://kerjainaja.vercel.app/blog/${post.id}` }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Apa yang dibahas di artikel ini?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": post.data.description
          }
        },
        {
          "@type": "Question",
          "name": "Apakah artikel ini gratis?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ya, semua artikel di KerjainAja gratis dan bisa diakses oleh siapa saja tanpa biaya."
          }
        }
      ]
    }
  ]
};
---

<Layout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  canonical={`https://kerjainaja.vercel.app/blog/${post.id}`}
  schema={postSchema}
>
  <article class="band-light">
    <div class="container post-container">
      <header class="post-header">
        <a href="/blog" class="back-link">← Kembali ke Blog</a>
        <h1>{post.data.title}</h1>
        <div class="post-meta">
          <span>{post.data.author}</span>
          <span>·</span>
          <time datetime={post.data.pubDate.toISOString()}>
            {new Intl.DateTimeFormat('id-ID', { dateStyle: 'long' }).format(post.data.pubDate)}
          </time>
        </div>
        {post.data.tags.length > 0 && (
          <div class="post-tags">
            {post.data.tags.map(tag => (<span class="tag">{tag}</span>))}
          </div>
        )}
      </header>
      <div class="post-content">
        <Content />
      </div>
    </div>
  </article>
</Layout>

<style>
  .post-container { max-width: 780px; margin: 0 auto; }
  .back-link {
    display: inline-block;
    font-size: 16px;
    line-height: 24px;
    color: var(--color-body-mid);
    margin-bottom: var(--space-xl);
    text-decoration: none;
  }
  .back-link:hover {
    color: var(--color-primary);
    text-decoration: none;
  }
  .post-header {
    margin-bottom: var(--space-3xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid rgba(32, 21, 21, 0.08);
  }
  .post-header h1 { font-size: 48px; line-height: 48px; margin-bottom: var(--space-xl); }
  .post-meta {
    font-size: 16px;
    line-height: 24px;
    color: var(--color-body-mid);
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }
  .post-tags { display: flex; gap: var(--space-xs); flex-wrap: wrap; }

  .post-content {
    font-size: 18px;
    line-height: 27px;
    color: var(--color-body);
  }
  .post-content h2 {
    font-size: 32px;
    font-weight: 500;
    line-height: 36px;
    letter-spacing: 1px;
    margin: var(--space-4xl) 0 var(--space-xl);
    color: var(--color-ink);
  }
  .post-content h3 {
    font-size: 24px;
    font-weight: 600;
    line-height: 30px;
    letter-spacing: -0.6px;
    margin: var(--space-3xl) 0 var(--space-lg);
    color: var(--color-ink);
  }
  .post-content h2:first-child { margin-top: 0; }
  .post-content p { margin-bottom: var(--space-lg); }
  .post-content ul, .post-content ol {
    margin: var(--space-lg) 0;
    padding-left: var(--space-xl);
  }
  .post-content li { margin-bottom: var(--space-sm); }
  .post-content img {
    margin: var(--space-2xl) 0;
    border-radius: var(--radius-md);
  }
  .post-content blockquote {
    border-left: 3px solid var(--color-primary);
    padding-left: var(--space-xl);
    margin: var(--space-2xl) 0;
    color: var(--color-ink-mid);
    font-style: italic;
  }
  .post-content code {
    background: var(--color-canvas-soft);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .post-content strong { color: var(--color-ink); }
  .post-content a { color: var(--color-primary); text-decoration: underline; }
  .post-content a:hover { color: var(--color-primary-hover); }

  .post-content table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: var(--space-2xl) 0;
    font-size: 15px;
    line-height: 22px;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 0 0 1px rgba(32, 21, 21, 0.08);
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .post-content th {
    background: var(--color-ink);
    color: var(--color-on-primary);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: var(--space-md) var(--space-lg);
    text-align: left;
    white-space: nowrap;
  }
  .post-content td {
    padding: var(--space-md) var(--space-lg);
    border-bottom: 1px solid rgba(32, 21, 21, 0.06);
    vertical-align: top;
  }
  .post-content tbody tr:last-child td {
    border-bottom: none;
  }
  .post-content tbody tr:nth-child(even) td {
    background: rgba(248, 244, 240, 0.5);
  }
  .post-content tbody tr:hover td {
    background: var(--color-canvas-soft);
  }

  /* Wrap tables in scroll container on mobile */
  .post-content .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: var(--space-2xl) 0;
  }
  .post-content .table-wrap table {
    margin: 0;
    min-width: 500px;
  }

  @media (max-width: 768px) {
    .post-container { max-width: 100%; }
    .post-header h1 { font-size: 32px; line-height: 36px; }
    .post-content h2 { font-size: 24px; line-height: 28px; }
  }
</style>
