---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Blog — Panduan & Tips Cari Kerja"
  description="Kumpulan artikel panduan cari kerja online di Indonesia. Tips CV, persiapan interview, review platform lowongan kerja, dan info karir terbaru."
  ogType="blog"
>
  <section class="band-light blog-hero">
    <div class="hero-bg bg-grid fade-mask" aria-hidden="true"></div>
    <div class="container blog-header">
      <span class="eyebrow" data-reveal>Blog</span>
      <h1 data-reveal style="--reveal-delay:.05s">Semua Panduan & Tips</h1>
      <p class="blog-sub" data-reveal style="--reveal-delay:.1s">Dapatkan tips terbaru seputar cara melamar kerja, bikin CV, persiapan interview, dan review platform lowongan kerja di Indonesia.</p>
    </div>
  </section>

  <section class="band-cream">
    <div class="container blog-list">
      {posts.length > 0 ? (
        posts.map((post, i) => (
          <article class="blog-card glow-card" data-reveal style={`--reveal-delay:${i * 0.06}s`}>
            <a href={`/blog/${post.id}`} class="blog-card-link">
              <div class="blog-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {new Intl.DateTimeFormat('id-ID', { dateStyle: 'long' }).format(post.data.pubDate)}
                </time>
                {post.data.tags.length > 0 && (
                  <div class="blog-tags">
                    {post.data.tags.slice(0, 3).map(tag => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
              <h2>{post.data.title}</h2>
              <p class="blog-excerpt">{post.data.description}</p>
              <span class="btn btn-text blog-card-cta">Baca selengkapnya →</span>
            </a>
          </article>
        ))
      ) : (
        <div class="empty-state">
          <p>Belum ada artikel. Pantau terus!</p>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .blog-hero { position: relative; overflow: hidden; }
  .blog-hero .hero-bg { position: absolute; inset: 0; z-index: 0; }
  .blog-header {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }
  .blog-header h1 {
    margin-bottom: var(--space-lg);
  }
  .blog-sub {
    font-size: 20px;
    line-height: 30px;
    letter-spacing: -0.2px;
    color: var(--color-body);
  }
  .blog-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
    max-width: 980px;
    margin: 0 auto;
  }
  .blog-card { background: var(--color-canvas); display: flex; }
  .blog-card-link {
    display: flex;
    flex-direction: column;
    padding: var(--space-2xl);
    text-decoration: none;
    color: inherit;
    height: 100%;
  }
  .blog-card-link:hover { text-decoration: none; }
  .blog-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
    font-size: 13px;
    line-height: 21px;
    color: var(--color-body-mid);
    flex-wrap: wrap;
  }
  .blog-tags { display: flex; gap: var(--space-xs); flex-wrap: wrap; }
  .blog-card h2 {
    font-size: 22px;
    font-weight: 600;
    line-height: 28px;
    letter-spacing: -0.6px;
    margin-bottom: var(--space-sm);
    transition: color 0.2s;
  }
  .blog-card:hover h2 { color: var(--color-primary); }
  .blog-excerpt {
    font-size: 15px;
    line-height: 23px;
    color: var(--color-body);
    margin-bottom: var(--space-lg);
    flex: 1;
  }
  .blog-card-cta { align-self: flex-start; padding-left: 0; padding-right: 0; }
  .empty-state {
    text-align: center;
    padding: var(--space-4xl) 0;
    color: var(--color-body-mid);
  }
  @media (max-width: 768px) {
    .blog-list { grid-template-columns: 1fr; }
  }
</style>
