---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Blog — Panduan & Tips Cari Kerja"
  description="Kumpulan artikel panduan cari kerja online di Indonesia. Tips CV, persiapan interview, review platform lowongan kerja, dan info karir terbaru."
  ogType="blog"
>
  <section class="band-light">
    <div class="container blog-header">
      <span class="eyebrow">Blog</span>
      <h1>Semua Panduan & Tips</h1>
      <p class="blog-sub">Dapatkan tips terbaru seputar cara melamar kerja, bikin CV, persiapan interview, dan review platform lowongan kerja di Indonesia.</p>
    </div>
  </section>

  <section class="band-cream">
    <div class="container blog-list">
      {posts.length > 0 ? (
        posts.map(post => (
          <article class="blog-card">
            <a href={`/blog/${post.id}`} class="blog-card-link">
              <div class="blog-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {new Intl.DateTimeFormat('id-ID', { dateStyle: 'long' }).format(post.data.pubDate)}
                </time>
                {post.data.tags.length > 0 && (
                  <div class="blog-tags">
                    {post.data.tags.slice(0, 3).map(tag => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
              <h2>{post.data.title}</h2>
              <p class="blog-excerpt">{post.data.description}</p>
              <span class="btn btn-text">Baca selengkapnya →</span>
            </a>
          </article>
        ))
      ) : (
        <div class="empty-state">
          <p>Belum ada artikel. Pantau terus!</p>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .blog-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }
  .blog-header h1 {
    margin-bottom: var(--space-lg);
  }
  .blog-sub {
    font-size: 20px;
    line-height: 30px;
    letter-spacing: -0.2px;
    color: var(--color-body);
  }
  .blog-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    max-width: 800px;
    margin: 0 auto;
  }
  .blog-card {
    background: var(--color-canvas);
    border-radius: var(--radius-md);
    transition: box-shadow 0.2s;
    box-shadow: var(--shadow-hairline);
  }
  .blog-card:hover {
    box-shadow: var(--shadow-soft);
  }
  .blog-card-link {
    display: block;
    padding: var(--space-xl);
    text-decoration: none;
    color: inherit;
  }
  .blog-card-link:hover { text-decoration: none; }
  .blog-meta {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    margin-bottom: var(--space-md);
    font-size: 14px;
    line-height: 21px;
    color: var(--color-body-mid);
  }
  .blog-tags { display: flex; gap: var(--space-xs); flex-wrap: wrap; }
  .blog-card h2 {
    font-size: 24px;
    font-weight: 600;
    line-height: 30px;
    letter-spacing: -0.6px;
    margin-bottom: var(--space-sm);
    transition: color 0.2s;
  }
  .blog-card:hover h2 { color: var(--color-primary); }
  .blog-excerpt {
    font-size: 16px;
    line-height: 24px;
    color: var(--color-body);
    margin-bottom: var(--space-lg);
  }
  .empty-state {
    text-align: center;
    padding: var(--space-4xl) 0;
    color: var(--color-body-mid);
  }
</style>
