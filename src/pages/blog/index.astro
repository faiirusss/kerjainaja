---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Blog — Panduan & Tips Cari Kerja"
  description="Kumpulan artikel panduan cari kerja online di Indonesia. Tips CV, persiapan interview, review platform lowongan kerja, dan info karir terbaru."
  ogType="blog"
>
  <section class="blog-hero">
    <div class="container blog-header">
      <span class="eyebrow">Blog</span>
      <h1>Semua Panduan &amp; Tips</h1>
      <p class="blog-sub">Dapatkan tips terbaru seputar cara melamar kerja, bikin CV, persiapan interview, dan review platform lowongan kerja di Indonesia.</p>
    </div>
  </section>

  <section class="blog-section">
    <div class="container blog-grid">
      {posts.length > 0 ? (
        posts.map((post, i) => (
          <article class="blog-card">
            <a href={`/blog/${post.id}`} class="blog-card-link">
              <div class="blog-card-body">
                <div class="blog-meta">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {new Intl.DateTimeFormat('id-ID', { dateStyle: 'long' }).format(post.data.pubDate)}
                  </time>
                </div>
                <h2>{post.data.title}</h2>
                <p class="blog-excerpt">{post.data.description}</p>
              </div>
              <div class="blog-card-footer">
                {post.data.tags.length > 0 && (
                  <div class="blog-tags">
                    {post.data.tags.slice(0, 3).map(tag => (
                      <span class="blog-tag">{tag}</span>
                    ))}
                  </div>
                )}
                <span class="blog-cta">Baca →</span>
              </div>
            </a>
          </article>
        ))
      ) : (
        <div class="empty-state">
          <p>Belum ada artikel. Pantau terus!</p>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ── */
  .blog-hero {
    padding: var(--space-4xl) 0 var(--space-3xl);
    text-align: center;
    background: linear-gradient(180deg, var(--color-canvas-soft) 0%, var(--color-canvas) 100%);
  }
  .blog-header {
    max-width: 680px;
    margin: 0 auto;
  }
  .blog-header h1 {
    margin-bottom: var(--space-lg);
  }
  .blog-sub {
    font-size: 18px;
    line-height: 28px;
    color: var(--color-body);
  }

  /* ── Blog Grid ── */
  .blog-section {
    padding: var(--space-4xl) 0;
    background: var(--color-canvas);
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Blog Card ── */
  .blog-card {
    background: var(--color-canvas);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                border-color 0.3s ease;
    display: flex;
  }
  .blog-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-card-hover);
    border-color: rgba(255, 79, 0, 0.25);
  }
  .blog-card-link {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-2xl);
    text-decoration: none;
    color: inherit;
    width: 100%;
  }
  .blog-card-link:hover { text-decoration: none; }

  .blog-card-body { flex: 1; }

  .blog-meta {
    font-size: 13px;
    color: var(--color-body-mid);
    margin-bottom: var(--space-md);
  }

  .blog-card h2 {
    font-size: 20px;
    font-weight: 600;
    line-height: 26px;
    letter-spacing: -0.4px;
    margin-bottom: var(--space-sm);
    color: var(--color-ink);
    transition: color 0.2s;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-card:hover h2 { color: var(--color-primary); }

  .blog-excerpt {
    font-size: 14px;
    line-height: 22px;
    color: var(--color-body);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--space-lg);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border-hair);
  }

  .blog-tags {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }
  .blog-tag {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-body-mid);
    background: var(--color-canvas-soft);
    padding: 2px 10px;
    border-radius: var(--radius-pill);
    line-height: 22px;
  }

  .blog-cta {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary);
    white-space: nowrap;
    transition: gap 0.2s;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-4xl) 0;
    color: var(--color-body-mid);
    grid-column: 1 / -1;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .blog-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .blog-hero { padding: var(--space-3xl) 0 var(--space-2xl); }
    .blog-section { padding: var(--space-3xl) 0; }
    .blog-grid { grid-template-columns: 1fr; max-width: 500px; }
    .blog-card h2 { font-size: 18px; line-height: 24px; }
  }
</style>
