---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  schema?: Record<string, any>;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
  noIndex?: boolean;
}

const { title, description, schema, ogImage, ogType, canonical, noIndex } = Astro.props;
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta name="google-site-verification" content="FgZwRAHw6Qwg7H5xHT5_twi-6F_1sYPJ9j9f7MRylZU" />
    <SEO
      title={title}
      description={description}
      schema={schema}
      ogImage={ogImage}
      ogType={ogType}
      canonical={canonical}
      noIndex={noIndex}
    />
  </head>
  <body>
    <Header />
    <main class="main container">
      <slot />
    </main>
    <Footer />
    <script>
      // Wrap all tables inside .post-content in a scrollable container
      document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.post-content table').forEach(function (table) {
          if (!table.parentElement.classList.contains('table-wrap')) {
            var wrapper = document.createElement('div');
            wrapper.className = 'table-wrap';
            wrapper.style.cssText = 'overflow-x: auto; -webkit-overflow-scrolling: touch; margin: 0;';
            table.parentNode.insertBefore(wrapper, table);
            wrapper.appendChild(table);
          }
        });
      });
    </script>
  </body>
</html>
